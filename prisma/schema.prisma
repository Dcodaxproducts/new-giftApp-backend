model User {
  id                                  String                               @id @default(cuid())
  email                               String                               @unique
  password                            String
  role                                UserRole                             @default(REGISTERED_USER)
  firstName                           String                               @map("first_name")
  lastName                            String                               @map("last_name")
  phone                               String?
  avatarUrl                           String?                              @map("avatar_url")
  location                            String?
  adminRoleId                         String?                              @map("admin_role_id")
  isVerified                          Boolean                              @default(false) @map("is_verified")
  isActive                            Boolean                              @default(true) @map("is_active")
  isApproved                          Boolean                              @default(true) @map("is_approved")
  mustChangePassword                  Boolean                              @default(false) @map("must_change_password")
  lastLoginAt                         DateTime?                            @map("last_login_at") @db.Timestamptz
  adminTitle                          String?                              @map("admin_title")
  adminPermissions                    Json?                                @map("admin_permissions")
  providerBusinessName                String?                              @map("provider_business_name")
  providerLegalName                   String?                              @map("provider_legal_name")
  providerBusinessCategoryId          String?                              @map("provider_business_category_id")
  providerTaxId                       String?                              @map("provider_tax_id")
  providerBusinessEmail               String?                              @map("provider_business_email")
  providerBusinessPhone               String?                              @map("provider_business_phone")
  providerBusinessAddress             String?                              @map("provider_business_address")
  providerStoreAddress                Json?                                @map("provider_store_address")
  providerBusinessHours               Json?                                @map("provider_business_hours")
  providerServiceArea                 String?                              @map("provider_service_area")
  providerWebsite                     String?                              @map("provider_website")
  providerFulfillmentMethods          Json?                                @map("provider_fulfillment_methods")
  providerAutoAcceptOrders            Boolean                              @default(false) @map("provider_auto_accept_orders")
  providerDocuments                   Json?                                @map("provider_documents")
  providerApprovalStatus              ProviderApprovalStatus?              @map("provider_approval_status")
  providerApprovedAt                  DateTime?                            @map("provider_approved_at") @db.Timestamptz
  providerApprovedBy                  String?                              @map("provider_approved_by")
  providerRejectedAt                  DateTime?                            @map("provider_rejected_at") @db.Timestamptz
  providerRejectedBy                  String?                              @map("provider_rejected_by")
  providerRejectionReason             String?                              @map("provider_rejection_reason")
  providerRejectionComment            String?                              @map("provider_rejection_comment")
  verificationOtp                     String?                              @map("verification_otp")
  verificationOtpExpiresAt            DateTime?                            @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts             Int                                  @default(0) @map("verification_otp_attempts")
  resetPasswordOtp                    String?                              @map("reset_password_otp")
  resetPasswordOtpExpiresAt           DateTime?                            @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts            Int                                  @default(0) @map("reset_password_otp_attempts")
  suspensionReason                    String?                              @map("suspension_reason")
  suspensionComment                   String?                              @map("suspension_comment")
  suspendedAt                         DateTime?                            @map("suspended_at") @db.Timestamptz
  suspendedBy                         String?                              @map("suspended_by")
  refreshTokenHash                    String?                              @map("refresh_token_hash")
  referralCode                        String?                              @unique @map("referral_code")
  deletedAt                           DateTime?                            @map("deleted_at") @db.Timestamptz
  deleteAfter                         DateTime?                            @map("delete_after") @db.Timestamptz
  createdAt                           DateTime                             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                           DateTime                             @updatedAt @map("updated_at") @db.Timestamptz
  loginAttempts                       LoginAttempt[]
  adminRole                           AdminRole?                           @relation(fields: [adminRoleId], references: [id])
  auditLogs                           AdminAuditLog[]                      @relation("AuditActor")
  accountSuspensions                  AccountSuspension[]                  @relation("SuspendedAccount")
  createdSuspensions                  AccountSuspension[]                  @relation("SuspensionActor")
  resolvedSuspensions                 AccountSuspension[]                  @relation("UnsuspensionActor")
  providerGifts                       Gift[]                               @relation("GiftProvider")
  approvedGifts                       Gift[]                               @relation("GiftApprover")
  rejectedGifts                       Gift[]                               @relation("GiftRejecter")
  flaggedGifts                        Gift[]                               @relation("GiftFlagger")
  promotionalOffers                   PromotionalOffer[]                   @relation("PromotionalOfferProvider")
  approvedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferApprover")
  rejectedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferRejecter")
  createdBroadcasts                   Broadcast[]                          @relation("BroadcastCreator")
  updatedBroadcasts                   Broadcast[]                          @relation("BroadcastUpdater")
  cancelledBroadcasts                 Broadcast[]                          @relation("BroadcastCanceller")
  notifications                       Notification[]
  deviceTokens                        NotificationDeviceToken[]
  notificationPreference              NotificationPreference?
  authSessions                        AuthSession[]
  payments                            Payment[]
  moneyGifts                          MoneyGift[]
  customerRecurringPayments           CustomerRecurringPayment[]
  customerRecurringPaymentOccurrences CustomerRecurringPaymentOccurrence[]
  customerPaymentMethods              CustomerPaymentMethod[]
  customerWallet                      CustomerWallet?
  customerWalletLedger                CustomerWalletLedger[]
  customerBankAccounts                CustomerBankAccount[]
  customerSubscriptions               CustomerSubscription[]
  customerSubscriptionInvoices        CustomerSubscriptionInvoice[]
  sentReferrals                       Referral[]                           @relation("ReferralReferrer")
  receivedReferrals                   Referral[]                           @relation("ReferralReferred")
  rewardLedger                        RewardLedger[]
  uploadedFiles                       UploadedFile[]
  updatedMediaUploadPolicies          MediaUploadPolicy[]                  @relation("MediaUploadPolicyUpdater")
  updatedReferralSettings             ReferralSettings[]                   @relation("ReferralSettingsUpdater")
  updatedRefundPolicySettings         RefundPolicySettings[]               @relation("RefundPolicySettingsUpdater")
  createdSubscriptionPlans            SubscriptionPlan[]                   @relation("SubscriptionPlanCreator")
  updatedSubscriptionPlans            SubscriptionPlan[]                   @relation("SubscriptionPlanUpdater")
  createdCoupons                      Coupon[]                             @relation("CouponCreator")
  updatedCoupons                      Coupon[]                             @relation("CouponUpdater")
  providerBusinessCategory            ProviderBusinessCategory?            @relation(fields: [providerBusinessCategoryId], references: [id])
  providerOrders                      ProviderOrder[]
  customerRefundRequests              RefundRequest[]                      @relation("RefundRequestCustomer")
  providerRefundRequests              RefundRequest[]                      @relation("RefundRequestProvider")
  providerOrderTimelines              ProviderOrderTimeline[]
  sentOrderMessages                   OrderMessage[]                       @relation("OrderMessageSender")
  receivedOrderMessages               OrderMessage[]                       @relation("OrderMessageRecipient")
  customerReviews                     Review[]                             @relation("ReviewCustomer")
  providerReviews                     Review[]                             @relation("ReviewProvider")
  reviewResponses                     ReviewResponse[]                     @relation("ReviewResponseProvider")
  reviewModerationLogs                ReviewModerationLog[]                @relation("ReviewModerationActor")
  updatedReviewPolicies               ReviewPolicy[]                       @relation("ReviewPolicyUpdater")
  customerChatThreads                 ChatThread[]                         @relation("CustomerChatThread")
  providerChatThreads                 ChatThread[]                         @relation("ProviderChatThread")
  sentChatMessages                    ChatMessage[]                        @relation("ChatMessageSender")
  submittedProviderReports            ProviderReport[]                     @relation("ProviderReportReporter")
  receivedProviderReports             ProviderReport[]                     @relation("ProviderReportProvider")
  reviewedProviderReports             ProviderReport[]                     @relation("ProviderReportReviewer")
  providerDisputeCases                DisputeCase[]                        @relation("DisputeProvider")
  disputeCases                        DisputeCase[]                        @relation("DisputeCustomer")
  assignedDisputes                    DisputeCase[]                        @relation("DisputeAssignee")
  disputeEvidenceUploads              DisputeEvidence[]                    @relation("DisputeEvidenceUploader")
  disputeNotes                        DisputeNote[]                        @relation("DisputeNoteAuthor")
  disputeTimelineEvents               DisputeTimeline[]                    @relation("DisputeTimelineActor")
  linkedDisputes                      DisputeCase[]                        @relation("DisputeLinker")
  providerDisputesAsProvider          ProviderDisputeCase[]                @relation("ProviderDisputeProvider")
  providerDisputesAsCustomer          ProviderDisputeCase[]                @relation("ProviderDisputeCustomer")
  assignedProviderDisputes            ProviderDisputeCase[]                @relation("ProviderDisputeAssignee")
  providerDisputeEvidenceUploads      ProviderDisputeEvidence[]            @relation("ProviderDisputeEvidenceSubmitter")
  providerDisputeNotes                ProviderDisputeNote[]                @relation("ProviderDisputeNoteAuthor")
  providerDisputeTimelineEvents       ProviderDisputeTimeline[]            @relation("ProviderDisputeTimelineActor")
  finalAttestedProviderDisputes       ProviderDisputeCase[]                @relation("ProviderDisputeFinalAttestor")
  finalizedProviderDisputeResolutions ProviderDisputeResolution[]          @relation("ProviderDisputeFinalizer")
  providerFinancialAdjustments        ProviderFinancialAdjustment[]
  providerPayoutMethods               ProviderPayoutMethod[]
  providerEarningsLedger              ProviderEarningsLedger[]
  providerPayouts                     ProviderPayout[]
  socialPosts                         SocialPost[]                         @relation("SocialPostAuthor")
  socialReports                       SocialReport[]                       @relation("SocialReportReporter")
  socialModerationLogs                SocialModerationLog[]                @relation("SocialModerationActor")
  socialWarnings                      UserWarning[]                        @relation("WarnedUser")
  issuedSocialWarnings                UserWarning[]                        @relation("WarningIssuer")

  @@index([role, isActive])
  @@index([role, suspendedAt])
  @@index([adminRoleId])
  @@index([providerApprovalStatus])
  @@index([providerBusinessCategoryId])
  @@index([referralCode])
  @@map("users")
}

model Referral {
  id                               String         @id @default(cuid())
  referrerUserId                   String         @map("referrer_user_id")
  referredUserId                   String         @unique @map("referred_user_id")
  referralCode                     String         @map("referral_code")
  status                           ReferralStatus @default(JOINED)
  rewardAmount                     Decimal        @default(0) @map("reward_amount") @db.Decimal(10, 2)
  currency                         String         @default("USD")
  referrerRewardAmountSnapshot     Decimal        @default(0) @map("referrer_reward_amount_snapshot") @db.Decimal(10, 2)
  newUserRewardAmountSnapshot      Decimal        @default(0) @map("new_user_reward_amount_snapshot") @db.Decimal(10, 2)
  rewardCurrencySnapshot           String         @default("USD") @map("reward_currency_snapshot")
  minimumTransactionAmountSnapshot Decimal        @default(0) @map("minimum_transaction_amount_snapshot") @db.Decimal(10, 2)
  expiresAt                        DateTime?      @map("expires_at") @db.Timestamptz
  joinedAt                         DateTime?      @map("joined_at") @db.Timestamptz
  qualifiedAt                      DateTime?      @map("qualified_at") @db.Timestamptz
  rewardedAt                       DateTime?      @map("rewarded_at") @db.Timestamptz
  createdAt                        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  referrer User @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred User @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@index([referrerUserId, status])
  @@index([referralCode])
  @@map("referrals")
}

model ReferralSettings {
  id                       String                    @id @default(cuid())
  isActive                 Boolean                   @default(true) @map("is_active")
  referrerRewardAmount     Decimal                   @default(10) @map("referrer_reward_amount") @db.Decimal(10, 2)
  newUserRewardAmount      Decimal                   @default(0) @map("new_user_reward_amount") @db.Decimal(10, 2)
  rewardCurrency           String                    @default("USD") @map("reward_currency")
  minimumTransactionAmount Decimal                   @default(0) @map("minimum_transaction_amount") @db.Decimal(10, 2)
  referralExpirationValue  Int                       @default(30) @map("referral_expiration_value")
  referralExpirationUnit   ReferralExpirationUnit    @default(DAYS) @map("referral_expiration_unit")
  allowSelfReferrals       Boolean                   @default(false) @map("allow_self_referrals")
  qualificationRule        ReferralQualificationRule @default(FIRST_SUCCESSFUL_PURCHASE) @map("qualification_rule")
  updatedById              String?                   @map("updated_by_id")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User? @relation("ReferralSettingsUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
  @@map("referral_settings")
}

