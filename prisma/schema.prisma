  sendMode           BroadcastSendMode? @map("send_mode")
  scheduledAt        DateTime?          @map("scheduled_at") @db.Timestamptz
  timezone           String?            @default("UTC")
  isRecurring        Boolean            @default(false) @map("is_recurring")
  recurrenceJson     Json?              @map("recurrence_json")
  createdBy          String             @map("created_by")
  updatedBy          String?            @map("updated_by")
  cancelledAt        DateTime?          @map("cancelled_at") @db.Timestamptz
  cancelledBy        String?            @map("cancelled_by")
  cancelReason       String?            @map("cancel_reason")
  startedAt          DateTime?          @map("started_at") @db.Timestamptz
  completedAt        DateTime?          @map("completed_at") @db.Timestamptz
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  creator   User  @relation("BroadcastCreator", fields: [createdBy], references: [id])
  updater   User? @relation("BroadcastUpdater", fields: [updatedBy], references: [id])
  canceller User? @relation("BroadcastCanceller", fields: [cancelledBy], references: [id])

  deliveries    BroadcastDelivery[]
  notifications Notification[]

  @@index([status, createdAt])
  @@index([scheduledAt, status])
  @@map("broadcasts")
}

model BroadcastDelivery {
  id                String                    @id @default(cuid())
  broadcastId       String                    @map("broadcast_id")
  recipientId       String                    @map("recipient_id")
  recipientType     NotificationRecipientType @map("recipient_type")
  channel           BroadcastChannel
  status            BroadcastDeliveryStatus   @default(QUEUED)
  email             String?
  deviceTokenId     String?                   @map("device_token_id")
  failureReason     String?                   @map("failure_reason")
  providerMessageId String?                   @map("provider_message_id")
  queuedAt          DateTime                  @default(now()) @map("queued_at") @db.Timestamptz
  sentAt            DateTime?                 @map("sent_at") @db.Timestamptz
  deliveredAt       DateTime?                 @map("delivered_at") @db.Timestamptz
  openedAt          DateTime?                 @map("opened_at") @db.Timestamptz
  clickedAt         DateTime?                 @map("clicked_at") @db.Timestamptz
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  broadcast Broadcast @relation(fields: [broadcastId], references: [id])

  @@index([broadcastId, status])
  @@index([recipientId, recipientType])
  @@map("broadcast_deliveries")
}

model Notification {
  id            String                    @id @default(cuid())
  recipientId   String                    @map("recipient_id")
  recipientType NotificationRecipientType @map("recipient_type")
  broadcastId   String?                   @map("broadcast_id")
  title         String
  message       String
  imageUrl      String?                   @map("image_url")
  iconKey       String?                   @map("icon_key")
  ctaUrl        String?                   @map("cta_url")
  metadataJson  Json?                     @map("metadata_json")
  actionsJson   Json?                     @map("actions_json")
  type          String                    @default("BROADCAST")
  isRead        Boolean                   @default(false) @map("is_read")
  readAt        DateTime?                 @map("read_at") @db.Timestamptz
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?                 @map("deleted_at") @db.Timestamptz

  recipient User       @relation(fields: [recipientId], references: [id])
  broadcast Broadcast? @relation(fields: [broadcastId], references: [id])

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, type, createdAt])
  @@index([deletedAt])
  @@index([broadcastId])
  @@map("notifications")
}

model NotificationDeviceToken {
