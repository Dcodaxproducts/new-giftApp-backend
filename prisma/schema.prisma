generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  REGISTERED_USER
  PROVIDER
}

enum ProviderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoginAttemptStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum AccountType {
  REGISTERED_USER
  PROVIDER
  ADMIN
}

enum GiftStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum GiftModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BroadcastChannel {
  EMAIL
  PUSH
  IN_APP
}

enum BroadcastPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  CANCELLED
  FAILED
}

enum BroadcastSendMode {
  NOW
  SCHEDULED
}

enum NotificationRecipientType {
  ADMIN
  PROVIDER
  REGISTERED_USER
}

enum BroadcastDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  OPENED
  CLICKED
}

enum NotificationDevicePlatform {
  IOS
  ANDROID
  WEB
}

enum SubscriptionPlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionPlanVisibility {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromotionalOfferDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromotionalOfferStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  INACTIVE
  PENDING
  REJECTED
}

enum PromotionalOfferApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionalOfferRejectionReason {
  INVALID_DISCOUNT
  INVALID_DATES
  POLICY_VIOLATION
  ITEM_NOT_ELIGIBLE
  INCOMPLETE_INFORMATION
  OTHER
}

enum UploadedFileStatus {
  PENDING
  COMPLETED
  FAILED
  DELETED
}

enum CustomerReminderEventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  CUSTOM
}

enum CustomerDeliveryOption {
  SAME_DAY
  NEXT_DAY
  SCHEDULED
}

enum CustomerEventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  WORK_MILESTONE
  CUSTOM
}

enum CustomerEventReminderTiming {
  ONE_DAY_BEFORE
  THREE_DAYS_BEFORE
  ONE_WEEK_BEFORE
  ON_THE_DAY
  CUSTOM
}

enum CustomerEventReminderFrequency {
  ONE_TIME
  MONTHLY
  YEARLY
}

enum CustomerEventReminderChannel {
  PUSH
  EMAIL
  SMS
}

enum CustomerEventReminderJobStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PARTIALLY_PROCESSING
  PARTIALLY_SHIPPED
  SHIPPED
  PARTIALLY_COMPLETED
  NEEDS_REVIEW
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum ProviderOrderStatus {
  PENDING
  ACCEPTED
  PROCESSING
  PACKED
  READY_FOR_PICKUP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REJECTED
  REFUNDED
}

enum ProviderOrderMessageChannel {
  IN_APP
  EMAIL
  SMS_PLACEHOLDER
}

enum ProviderOrderRejectReason {
  OUT_OF_STOCK
  BUSINESS_CLOSED
  CANNOT_DELIVER_TO_AREA
  PRICING_ERROR
  OTHER
}

enum RefundRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  REFUND_PROCESSING
  REFUNDED
  FAILED
}

enum RefundRejectReason {
  ITEM_DELIVERED_AS_DESCRIBED
  NO_DAMAGE_EVIDENCE
  REFUND_WINDOW_EXPIRED
  NOT_COVERED_BY_POLICY
  OTHER
}

enum PaymentMethod {
  STRIPE_CARD
  E_WALLET
  BANK_TRANSFER
  COD
  PLACEHOLDER
}

enum PaymentProvider {
  STRIPE
  MANUAL
}

enum MoneyGiftStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

enum CustomerRecurringPaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum CustomerRecurringPaymentStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  FAILED
}

enum CustomerRecurringPaymentOccurrenceStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
  CANCELLED
}

enum CustomerRecurringPaymentCancelMode {
  IMMEDIATELY
  AFTER_CURRENT_BILLING_CYCLE
}

enum ReferralStatus {
  PENDING
  JOINED
  QUALIFIED
  REWARDED
  EXPIRED
}

enum RewardLedgerType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

enum RewardLedgerSource {
  REFERRAL
  ADMIN_ADJUSTMENT
  PROMOTION
}

enum ReferralExpirationUnit {
  DAYS
  WEEKS
  MONTHS
}

enum ReferralQualificationRule {
  FIRST_SUCCESSFUL_PURCHASE
}

enum CustomerWalletLedgerType {
  TOP_UP
  GIFT_SENT
  MONEY_GIFT_SENT
  REWARD_CREDIT
  REFUND
  ADJUSTMENT
}

enum CustomerWalletLedgerDirection {
  CREDIT
  DEBIT
}

enum CustomerWalletLedgerStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum ProviderFulfillmentMethod {
  PICKUP
  DELIVERY
}

model User {
  id                                  String                               @id @default(cuid())
  email                               String                               @unique
  password                            String
  role                                UserRole                             @default(REGISTERED_USER)
  firstName                           String                               @map("first_name")
  lastName                            String                               @map("last_name")
  phone                               String?
  avatarUrl                           String?                              @map("avatar_url")
  location                            String?
  adminRoleId                         String?                              @map("admin_role_id")
  isVerified                          Boolean                              @default(false) @map("is_verified")
  isActive                            Boolean                              @default(true) @map("is_active")
  isApproved                          Boolean                              @default(true) @map("is_approved")
  mustChangePassword                  Boolean                              @default(false) @map("must_change_password")
  lastLoginAt                         DateTime?                            @map("last_login_at") @db.Timestamptz
  adminTitle                          String?                              @map("admin_title")
  adminPermissions                    Json?                                @map("admin_permissions")
  providerBusinessName                String?                              @map("provider_business_name")
  providerBusinessCategoryId          String?                              @map("provider_business_category_id")
  providerTaxId                       String?                              @map("provider_tax_id")
  providerBusinessAddress             String?                              @map("provider_business_address")
  providerServiceArea                 String?                              @map("provider_service_area")
  providerWebsite                     String?                              @map("provider_website")
  providerFulfillmentMethods          Json?                                @map("provider_fulfillment_methods")
  providerAutoAcceptOrders            Boolean                              @default(false) @map("provider_auto_accept_orders")
  providerDocuments                   Json?                                @map("provider_documents")
  providerApprovalStatus              ProviderApprovalStatus?              @map("provider_approval_status")
  providerApprovedAt                  DateTime?                            @map("provider_approved_at") @db.Timestamptz
  providerApprovedBy                  String?                              @map("provider_approved_by")
  providerRejectedAt                  DateTime?                            @map("provider_rejected_at") @db.Timestamptz
  providerRejectedBy                  String?                              @map("provider_rejected_by")
  providerRejectionReason             String?                              @map("provider_rejection_reason")
  providerRejectionComment            String?                              @map("provider_rejection_comment")
  verificationOtp                     String?                              @map("verification_otp")
  verificationOtpExpiresAt            DateTime?                            @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts             Int                                  @default(0) @map("verification_otp_attempts")
  resetPasswordOtp                    String?                              @map("reset_password_otp")
  resetPasswordOtpExpiresAt           DateTime?                            @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts            Int                                  @default(0) @map("reset_password_otp_attempts")
  suspensionReason                    String?                              @map("suspension_reason")
  suspensionComment                   String?                              @map("suspension_comment")
  suspendedAt                         DateTime?                            @map("suspended_at") @db.Timestamptz
  suspendedBy                         String?                              @map("suspended_by")
  refreshTokenHash                    String?                              @map("refresh_token_hash")
  referralCode                        String?                              @unique @map("referral_code")
  deletedAt                           DateTime?                            @map("deleted_at") @db.Timestamptz
  deleteAfter                         DateTime?                            @map("delete_after") @db.Timestamptz
  createdAt                           DateTime                             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                           DateTime                             @updatedAt @map("updated_at") @db.Timestamptz
  loginAttempts                       LoginAttempt[]
  adminRole                           AdminRole?                           @relation(fields: [adminRoleId], references: [id])
  auditLogs                           AdminAuditLog[]                      @relation("AuditActor")
  accountSuspensions                  AccountSuspension[]                  @relation("SuspendedAccount")
  createdSuspensions                  AccountSuspension[]                  @relation("SuspensionActor")
  resolvedSuspensions                 AccountSuspension[]                  @relation("UnsuspensionActor")
  providerGifts                       Gift[]                               @relation("GiftProvider")
  approvedGifts                       Gift[]                               @relation("GiftApprover")
  rejectedGifts                       Gift[]                               @relation("GiftRejecter")
  flaggedGifts                        Gift[]                               @relation("GiftFlagger")
  promotionalOffers                   PromotionalOffer[]                   @relation("PromotionalOfferProvider")
  approvedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferApprover")
  rejectedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferRejecter")
  createdBroadcasts                   Broadcast[]                          @relation("BroadcastCreator")
  updatedBroadcasts                   Broadcast[]                          @relation("BroadcastUpdater")
  cancelledBroadcasts                 Broadcast[]                          @relation("BroadcastCanceller")
  notifications                       Notification[]
  deviceTokens                        NotificationDeviceToken[]
  notificationPreference              NotificationPreference?
  authSessions                        AuthSession[]
  payments                            Payment[]
  moneyGifts                          MoneyGift[]
  customerRecurringPayments           CustomerRecurringPayment[]
  customerRecurringPaymentOccurrences CustomerRecurringPaymentOccurrence[]
  customerPaymentMethods              CustomerPaymentMethod[]
  customerWallet                      CustomerWallet?
  customerWalletLedger                CustomerWalletLedger[]
  customerBankAccounts                CustomerBankAccount[]
  sentReferrals                       Referral[]                           @relation("ReferralReferrer")
  receivedReferrals                   Referral[]                           @relation("ReferralReferred")
  rewardLedger                        RewardLedger[]
  uploadedFiles                       UploadedFile[]
  updatedMediaUploadPolicies          MediaUploadPolicy[]                  @relation("MediaUploadPolicyUpdater")
  updatedReferralSettings             ReferralSettings[]                   @relation("ReferralSettingsUpdater")
  createdSubscriptionPlans            SubscriptionPlan[]                   @relation("SubscriptionPlanCreator")
  updatedSubscriptionPlans            SubscriptionPlan[]                   @relation("SubscriptionPlanUpdater")
  createdCoupons                      Coupon[]                             @relation("CouponCreator")
  updatedCoupons                      Coupon[]                             @relation("CouponUpdater")
  providerBusinessCategory            ProviderBusinessCategory?            @relation(fields: [providerBusinessCategoryId], references: [id])
  providerOrders                      ProviderOrder[]
  customerRefundRequests              RefundRequest[]                     @relation("RefundRequestCustomer")
  providerRefundRequests              RefundRequest[]                     @relation("RefundRequestProvider")
  providerOrderTimelines              ProviderOrderTimeline[]
  sentOrderMessages                   OrderMessage[]                       @relation("OrderMessageSender")
  receivedOrderMessages               OrderMessage[]                       @relation("OrderMessageRecipient")

  @@index([role, isActive])
  @@index([role, suspendedAt])
  @@index([adminRoleId])
  @@index([providerApprovalStatus])
  @@index([providerBusinessCategoryId])
  @@index([referralCode])
  @@map("users")
}

model Referral {
  id                               String         @id @default(cuid())
  referrerUserId                   String         @map("referrer_user_id")
  referredUserId                   String         @unique @map("referred_user_id")
  referralCode                     String         @map("referral_code")
  status                           ReferralStatus @default(JOINED)
  rewardAmount                     Decimal        @default(0) @map("reward_amount") @db.Decimal(10, 2)
  currency                         String         @default("USD")
  referrerRewardAmountSnapshot     Decimal        @default(0) @map("referrer_reward_amount_snapshot") @db.Decimal(10, 2)
  newUserRewardAmountSnapshot      Decimal        @default(0) @map("new_user_reward_amount_snapshot") @db.Decimal(10, 2)
  rewardCurrencySnapshot           String         @default("USD") @map("reward_currency_snapshot")
  minimumTransactionAmountSnapshot Decimal        @default(0) @map("minimum_transaction_amount_snapshot") @db.Decimal(10, 2)
  expiresAt                        DateTime?      @map("expires_at") @db.Timestamptz
  joinedAt                         DateTime?      @map("joined_at") @db.Timestamptz
  qualifiedAt                      DateTime?      @map("qualified_at") @db.Timestamptz
  rewardedAt                       DateTime?      @map("rewarded_at") @db.Timestamptz
  createdAt                        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  referrer User @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred User @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@index([referrerUserId, status])
  @@index([referralCode])
  @@map("referrals")
}

model ReferralSettings {
  id                       String                    @id @default(cuid())
  isActive                 Boolean                   @default(true) @map("is_active")
  referrerRewardAmount     Decimal                   @default(10) @map("referrer_reward_amount") @db.Decimal(10, 2)
  newUserRewardAmount      Decimal                   @default(0) @map("new_user_reward_amount") @db.Decimal(10, 2)
  rewardCurrency           String                    @default("USD") @map("reward_currency")
  minimumTransactionAmount Decimal                   @default(0) @map("minimum_transaction_amount") @db.Decimal(10, 2)
  referralExpirationValue  Int                       @default(30) @map("referral_expiration_value")
  referralExpirationUnit   ReferralExpirationUnit    @default(DAYS) @map("referral_expiration_unit")
  allowSelfReferrals       Boolean                   @default(false) @map("allow_self_referrals")
  qualificationRule        ReferralQualificationRule @default(FIRST_SUCCESSFUL_PURCHASE) @map("qualification_rule")
  updatedById              String?                   @map("updated_by_id")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User? @relation("ReferralSettingsUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
  @@map("referral_settings")
}

model RewardLedger {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  type        RewardLedgerType
  amount      Decimal            @db.Decimal(10, 2)
  currency    String             @default("USD")
  source      RewardLedgerSource
  sourceId    String?            @map("source_id")
  description String
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type, source, sourceId])
  @@index([userId, type, createdAt])
  @@index([source, sourceId])
  @@map("reward_ledgers")
}

model CustomerWallet {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  cashBalance Decimal  @default(0) @map("cash_balance") @db.Decimal(10, 2)
  giftCredits Decimal  @default(0) @map("gift_credits") @db.Decimal(10, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User                   @relation(fields: [userId], references: [id])
  ledger CustomerWalletLedger[]

  @@map("customer_wallets")
}

model CustomerWalletLedger {
  id             String                        @id @default(cuid())
  userId         String                        @map("user_id")
  walletId       String                        @map("wallet_id")
  type           CustomerWalletLedgerType
  direction      CustomerWalletLedgerDirection
  amount         Decimal                       @db.Decimal(10, 2)
  currency       String                        @default("USD")
  status         CustomerWalletLedgerStatus    @default(PENDING)
  paymentId      String?                       @map("payment_id")
  orderId        String?                       @map("order_id")
  moneyGiftId    String?                       @map("money_gift_id")
  rewardLedgerId String?                       @map("reward_ledger_id")
  transactionId  String                        @unique @map("transaction_id")
  description    String
  createdAt      DateTime                      @default(now()) @map("created_at") @db.Timestamptz

  user   User           @relation(fields: [userId], references: [id])
  wallet CustomerWallet @relation(fields: [walletId], references: [id])

  @@index([userId, type, status, createdAt])
  @@index([walletId, createdAt])
  @@index([paymentId])
  @@index([rewardLedgerId])
  @@map("customer_wallet_ledgers")
}

model CustomerBankAccount {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  accountHolderName String    @map("account_holder_name")
  bankName          String    @map("bank_name")
  maskedAccount     String    @map("masked_account")
  last4             String
  isDefault         Boolean   @default(false) @map("is_default")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, deletedAt])
  @@index([userId, isDefault])
  @@map("customer_bank_accounts")
}

model ProviderBusinessCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  iconKey     String?   @map("icon_key")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  providers User[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("provider_business_categories")
}

model GiftCategory {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?
  iconKey         String?   @map("icon_key")
  color           String?
  backgroundColor String?   @default("#F3E8FF") @map("background_color")
  imageUrl        String?   @map("image_url")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  gifts Gift[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("gift_categories")
}

model CustomerWishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  giftId    String   @map("gift_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, giftId])
  @@index([userId])
  @@index([giftId])
  @@map("customer_wishlists")
}

model CustomerAddress {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  label                String
  fullName             String    @map("full_name")
  phone                String
  line1                String
  line2                String?
  city                 String
  state                String?
  country              String
  postalCode           String?   @map("postal_code")
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  deliveryInstructions String?   @map("delivery_instructions")
  isDefault            Boolean   @default(false) @map("is_default")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  @@index([userId, deletedAt])
  @@index([userId, isDefault])
  @@map("customer_addresses")
}

model CustomerReminder {
  id            String                    @id @default(cuid())
  userId        String                    @map("user_id")
  title         String
  recipientName String                    @map("recipient_name")
  eventType     CustomerReminderEventType @map("event_type")
  reminderDate  DateTime                  @map("reminder_date") @db.Timestamptz
  notes         String?
  isActive      Boolean                   @default(true) @map("is_active")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?                 @map("deleted_at") @db.Timestamptz

  @@index([userId, deletedAt])
  @@index([reminderDate, isActive])
  @@map("customer_reminders")
}

model CustomerContact {
  id                String                     @id @default(cuid())
  userId            String                     @map("user_id")
  name              String
  relationship      String?
  phone             String?
  email             String?
  address           String?
  likes             String?
  avatarUrl         String?                    @map("avatar_url")
  birthday          DateTime?                  @db.Date
  notes             String?
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?                  @map("deleted_at") @db.Timestamptz
  events            CustomerEvent[]
  moneyGifts        MoneyGift[]
  recurringPayments CustomerRecurringPayment[]

  @@index([userId])
  @@index([userId, name])
  @@index([userId, relationship])
  @@index([userId, deletedAt])
  @@map("customer_contacts")
}

model CustomerEvent {
  id                 String                         @id @default(cuid())
  userId             String                         @map("user_id")
  recipientId        String?                        @map("recipient_id")
  eventType          CustomerEventType              @map("event_type")
  title              String
  eventDate          DateTime                       @map("event_date") @db.Timestamptz
  reminderTiming     CustomerEventReminderTiming    @default(ON_THE_DAY) @map("reminder_timing")
  reminderFrequency  CustomerEventReminderFrequency @default(ONE_TIME) @map("reminder_frequency")
  customAlertTime    String?                        @map("custom_alert_time")
  channelsJson       Json                           @default("[\"PUSH\"]") @map("channels_json")
  notes              String?
  isActive           Boolean                        @default(true) @map("is_active")
  lastReminderSentAt DateTime?                      @map("last_reminder_sent_at") @db.Timestamptz
  nextReminderAt     DateTime?                      @map("next_reminder_at") @db.Timestamptz
  createdAt          DateTime                       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?                      @map("deleted_at") @db.Timestamptz
  recipient          CustomerContact?               @relation(fields: [recipientId], references: [id])
  reminderJobs       CustomerEventReminderJob[]

  @@index([userId, deletedAt])
  @@index([userId, eventDate])
  @@index([userId, eventType])
  @@index([recipientId])
  @@map("customer_events")
}

model CustomerEventReminderJob {
  id            String                         @id @default(cuid())
  eventId       String                         @map("event_id")
  userId        String                         @map("user_id")
  scheduledFor  DateTime                       @map("scheduled_for") @db.Timestamptz
  channel       CustomerEventReminderChannel
  status        CustomerEventReminderJobStatus @default(PENDING)
  failureReason String?                        @map("failure_reason")
  sentAt        DateTime?                      @map("sent_at") @db.Timestamptz
