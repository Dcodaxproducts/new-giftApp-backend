  @@index([isActive, expiresAt])
  @@index([deletedAt])
  @@map("coupons")
}

model AdminRole {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  permissions Json      @map("permissions_json")
  isSystem    Boolean   @default(false) @map("is_system")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  admins User[]

  @@index([isActive, isSystem])
  @@map("admin_roles")
}

model AdminAuditLog {
  id                  String           @id @default(cuid())
  logReference        String?          @unique @map("log_reference")
  eventId             String?          @map("event_id")
  actorId             String?          @map("actor_id")
  actorType           String?          @map("actor_type")
  actorNameSnapshot   String?          @map("actor_name_snapshot")
  targetId            String?          @map("target_id")
  targetType          String?          @map("target_type")
  action              String
  actionLabel         String?          @map("action_label")
  module              String?
  environment         String?          @map("environment")
  status              AuditLogStatus   @default(SUCCESS)
  severity            AuditLogSeverity @default(LOW)
  beforeJson          Json?            @map("before_json")
  afterJson           Json?            @map("after_json")
  requestPayloadJson  Json?            @map("request_payload_json")
  responsePayloadJson Json?            @map("response_payload_json")
  metadataJson        Json?            @map("metadata_json")
  ipAddress           String?          @map("ip_address")
  userAgent           String?          @map("user_agent")
  durationMs          Int?             @map("duration_ms")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@index([targetType, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
  @@index([module, createdAt])
  @@map("admin_audit_logs")
}

model AccountSuspension {
  id            String      @id @default(cuid())
  accountId     String      @map("account_id")
  accountType   AccountType @map("account_type")
  reason        String
  comment       String?
  suspendedBy   String      @map("suspended_by")
  suspendedAt   DateTime    @default(now()) @map("suspended_at") @db.Timestamptz
  unsuspendedBy String?     @map("unsuspended_by")
  unsuspendedAt DateTime?   @map("unsuspended_at") @db.Timestamptz
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  account        User  @relation("SuspendedAccount", fields: [accountId], references: [id])
  suspendActor   User  @relation("SuspensionActor", fields: [suspendedBy], references: [id])
  unsuspendActor User? @relation("UnsuspensionActor", fields: [unsuspendedBy], references: [id])

  @@index([accountId, isActive])
  @@index([accountType, isActive])
  @@index([suspendedBy, suspendedAt])
  @@map("account_suspensions")
}

model LoginAttempt {
  id        String             @id @default(cuid())
  email     String
  status    LoginAttemptStatus
  reason    String?
  ipAddress String?            @map("ip_address")
  userAgent String?            @map("user_agent")
  userId    String?            @map("user_id")
  role      UserRole?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("login_attempts")
}
