model User {
  id                                  String                               @id @default(cuid())
  email                               String                               @unique
  password                            String
  role                                UserRole                             @default(REGISTERED_USER)
  status                              UserStatus                           @default(PENDING)
  firstName                           String                               @map("first_name")
  lastName                            String                               @map("last_name")
  phone                               String?
  avatarUrl                           String?                              @map("avatar_url")
  location                            String?
  mustChangePassword                  Boolean                              @default(false) @map("must_change_password")
  lastLoginAt                         DateTime?                            @map("last_login_at") @db.Timestamptz
  verificationOtp                     String?                              @map("verification_otp")
  verificationOtpExpiresAt            DateTime?                            @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts             Int                                  @default(0) @map("verification_otp_attempts")
  resetPasswordOtp                    String?                              @map("reset_password_otp")
  resetPasswordOtpExpiresAt           DateTime?                            @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts            Int                                  @default(0) @map("reset_password_otp_attempts")
  suspensionReason                    String?                              @map("suspension_reason")
  suspensionComment                   String?                              @map("suspension_comment")
  refreshTokenHash                    String?                              @map("refresh_token_hash")
  referralCode                        String?                              @unique @map("referral_code")
  createdAt                           DateTime                             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                           DateTime                             @updatedAt @map("updated_at") @db.Timestamptz
  staffProfile                        StaffProfile?
  providerProfile                     ProviderProfile?
  customerProfile                     CustomerProfile?
  auditLogs                           AdminAuditLog[]                      @relation("AuditActor")
  providerGifts                       Gift[]                               @relation("GiftProvider")
  promotionalOffers                   PromotionalOffer[]                   @relation("PromotionalOfferProvider")
  approvedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferApprover")
  rejectedPromotionalOffers           PromotionalOffer[]                   @relation("PromotionalOfferRejecter")
  createdBroadcasts                   Broadcast[]                          @relation("BroadcastCreator")
  updatedBroadcasts                   Broadcast[]                          @relation("BroadcastUpdater")
  notifications                       Notification[]
  deviceTokens                        NotificationDeviceToken[]
  notificationPreference              NotificationPreference?
  authSessions                        AuthSession[]
  payments                            Payment[]
  moneyGifts                          MoneyGift[]
  customerRecurringPayments           CustomerRecurringPayment[]
  customerRecurringPaymentOccurrences CustomerRecurringPaymentOccurrence[]
  customerPaymentMethods              CustomerPaymentMethod[]
  customerWallet                      CustomerWallet?
  customerWalletLedger                CustomerWalletLedger[]
  customerBankAccounts                CustomerBankAccount[]
  customerSubscriptions               CustomerSubscription[]
  customerSubscriptionInvoices        CustomerSubscriptionInvoice[]
  sentReferrals                       Referral[]                           @relation("ReferralReferrer")
  receivedReferrals                   Referral[]                           @relation("ReferralReferred")
  rewardLedger                        RewardLedger[]
  uploadedFiles                       UploadedFile[]
  updatedReferralSettings             ReferralSettings[]                   @relation("ReferralSettingsUpdater")
  updatedRefundPolicySettings         RefundPolicySettings[]               @relation("RefundPolicySettingsUpdater")
  createdCoupons                      Coupon[]                             @relation("CouponCreator")
  updatedCoupons                      Coupon[]                             @relation("CouponUpdater")
  providerOrders                      ProviderOrder[]
  customerRefundRequests              RefundRequest[]                      @relation("RefundRequestCustomer")
  providerRefundRequests              RefundRequest[]                      @relation("RefundRequestProvider")
  providerOrderTimelines              ProviderOrderTimeline[]
  customerReviews                     Review[]                             @relation("ReviewCustomer")
  providerReviews                     Review[]                             @relation("ReviewProvider")
  reviewResponses                     ReviewResponse[]                     @relation("ReviewResponseProvider")
  updatedReviewPolicies               ReviewPolicy[]                       @relation("ReviewPolicyUpdater")
  customerChatThreads                 ChatThread[]                         @relation("CustomerChatThread")
  providerChatThreads                 ChatThread[]                         @relation("ProviderChatThread")
  assignedChatThreads                 ChatThread[]                         @relation("AssignedChatAdmin")
  resolvedChatThreads                 ChatThread[]                         @relation("ResolvedChatAdmin")
  sentChatMessages                    ChatMessage[]                        @relation("ChatMessageSender")
  chatParticipants                    ChatParticipant[]                    @relation("ChatParticipantUser")
  chatReadReceipts                    ChatMessageReadReceipt[]             @relation("ChatReadReceiptUser")
  submittedProviderReports            ProviderReport[]                     @relation("ProviderReportReporter")
  receivedProviderReports             ProviderReport[]                     @relation("ProviderReportProvider")
  reviewedProviderReports             ProviderReport[]                     @relation("ProviderReportReviewer")
  disputesAsUser                      Dispute[]                            @relation("DisputeUser")
  disputesAsProvider                  Dispute[]                            @relation("DisputeProvider")
  providerPayoutMethods               ProviderPayoutMethod[]
  providerEarningsLedger              ProviderEarningsLedger[]
  providerPayouts                     ProviderPayout[]
  updatedPayoutSettings               AdminPayoutSettings[]                @relation("AdminPayoutSettingsUpdater")
  updatedSystemSettings               SystemSettings[]                     @relation("SystemSettingsUpdater")
  updatedMessagingSettings            MessagingSettings[]                  @relation("MessagingSettingsUpdater")
  updatedCommissionTiers              CommissionTier[]                     @relation("CommissionTierUpdater")
  socialPosts                         SocialPost[]                         @relation("SocialPostAuthor")
  socialReports                       SocialReport[]                       @relation("SocialReportReporter")
  submittedUserSafetyReports          UserSafetyReport[]                   @relation("UserSafetyReporter")
  receivedUserSafetyReports           UserSafetyReport[]                   @relation("UserSafetyReported")
  reviewedUserSafetyReports           UserSafetyReport[]                   @relation("UserSafetyReviewer")
  blockedUsers                        UserBlock[]                          @relation("UserBlockBlocker")
  blockedByUsers                      UserBlock[]                          @relation("UserBlockBlocked")
  socialWarnings                      UserWarning[]                        @relation("WarnedUser")
  issuedSocialWarnings                UserWarning[]                        @relation("WarningIssuer")

  @@index([role, status])
  @@index([referralCode])
  @@map("users")
}

model StaffProfile {
  id          String  @id @default(cuid())
  userId      String  @unique @map("user_id")
  staffRoleId String? @map("staff_role_id")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffRole StaffRole? @relation(fields: [staffRoleId], references: [id])

  @@index([staffRoleId])
  @@map("staff_profiles")
}

model ProviderProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique @map("user_id")
  businessName       String?                 @map("business_name")
  legalName          String?                 @map("legal_name")
  businessCategoryId String?                 @map("business_category_id")
  taxId              String?                 @map("tax_id")
  businessEmail      String?                 @map("business_email")
  businessPhone      String?                 @map("business_phone")
  businessAddress    String?                 @map("business_address")
  fulfillmentMethods Json?                   @map("fulfillment_methods")
  autoAcceptOrders   Boolean                 @default(false) @map("auto_accept_orders")
  documents          Json?
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessCategory ProviderBusinessCategory? @relation(fields: [businessCategoryId], references: [id])

  @@index([businessCategoryId])
  @@map("provider_profiles")
}

model CustomerProfile {
  id                      String    @id @default(cuid())
  userId                  String    @unique @map("user_id")
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  gender                  String?
  preferredCurrency       String    @default("USD") @map("preferred_currency")
  preferredLanguage       String    @default("en") @map("preferred_language")
  marketingOptIn          Boolean   @default(false) @map("marketing_opt_in")
  giftPreferencesJson     Json      @default("{}") @map("gift_preferences_json")
  occasionPreferencesJson Json      @default("{}") @map("occasion_preferences_json")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model Referral {
  id                               String         @id @default(cuid())
  referrerUserId                   String         @map("referrer_user_id")
  referredUserId                   String         @unique @map("referred_user_id")
  referralCode                     String         @map("referral_code")
  status                           ReferralStatus @default(JOINED)
  rewardAmount                     Decimal        @default(0) @map("reward_amount") @db.Decimal(10, 2)
  currency                         String         @default("USD")
  referrerRewardAmountSnapshot     Decimal        @default(0) @map("referrer_reward_amount_snapshot") @db.Decimal(10, 2)
  newUserRewardAmountSnapshot      Decimal        @default(0) @map("new_user_reward_amount_snapshot") @db.Decimal(10, 2)
  rewardCurrencySnapshot           String         @default("USD") @map("reward_currency_snapshot")
  minimumTransactionAmountSnapshot Decimal        @default(0) @map("minimum_transaction_amount_snapshot") @db.Decimal(10, 2)
  expiresAt                        DateTime?      @map("expires_at") @db.Timestamptz
  joinedAt                         DateTime?      @map("joined_at") @db.Timestamptz
  qualifiedAt                      DateTime?      @map("qualified_at") @db.Timestamptz
  rewardedAt                       DateTime?      @map("rewarded_at") @db.Timestamptz
  createdAt                        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  referrer User @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred User @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@index([referrerUserId, status])
  @@index([referralCode])
  @@map("referrals")
}

model ReferralSettings {
  id                       String                    @id @default(cuid())
  isActive                 Boolean                   @default(true) @map("is_active")
  referrerRewardAmount     Decimal                   @default(10) @map("referrer_reward_amount") @db.Decimal(10, 2)
  newUserRewardAmount      Decimal                   @default(0) @map("new_user_reward_amount") @db.Decimal(10, 2)
  rewardCurrency           String                    @default("USD") @map("reward_currency")
  minimumTransactionAmount Decimal                   @default(0) @map("minimum_transaction_amount") @db.Decimal(10, 2)
  referralExpirationValue  Int                       @default(30) @map("referral_expiration_value")
  referralExpirationUnit   ReferralExpirationUnit    @default(DAYS) @map("referral_expiration_unit")
  allowSelfReferrals       Boolean                   @default(false) @map("allow_self_referrals")
  qualificationRule        ReferralQualificationRule @default(FIRST_SUCCESSFUL_PURCHASE) @map("qualification_rule")
  updatedById              String?                   @map("updated_by_id")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User? @relation("ReferralSettingsUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
  @@map("referral_settings")
}

model RefundPolicySettings {
  id                        String   @id @default(cuid())
  allowRefund               Boolean  @default(true) @map("allow_refund")
  noteText                  String?  @map("note_text")
  refundWindowDays          Int      @default(30) @map("refund_window_days")
  autoRefundThresholdAmount Decimal  @default(50) @map("auto_refund_threshold_amount") @db.Decimal(10, 2)
  currency                  String   @default("PKR")
  cancellationTiersJson     Json     @default("[]") @map("cancellation_tiers_json")
  updatedById               String?  @map("updated_by_id")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User? @relation("RefundPolicySettingsUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
  @@map("refund_policy_settings")
}

model RewardLedger {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  type        RewardLedgerType
  amount      Decimal            @db.Decimal(10, 2)
  currency    String             @default("USD")
  source      RewardLedgerSource
  sourceId    String?            @map("source_id")
  description String
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type, source, sourceId])
  @@index([userId, type, createdAt])
  @@index([source, sourceId])
  @@map("reward_ledgers")
}

model CustomerWallet {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  cashBalance Decimal  @default(0) @map("cash_balance") @db.Decimal(10, 2)
  giftCredits Decimal  @default(0) @map("gift_credits") @db.Decimal(10, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

