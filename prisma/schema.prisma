  status                       SubscriptionPlanStatus     @default(ACTIVE)
  visibility                   SubscriptionPlanVisibility @default(PUBLIC)
  isPopular                    Boolean                    @default(false) @map("is_popular")
  featuresJson                 Json                       @default("{}") @map("features_json")
  limitsJson                   Json                       @default("{}") @map("limits_json")
  activeSubscribersPlaceholder Int                        @default(0) @map("active_subscribers_placeholder")
  stripeProductId              String?                    @map("stripe_product_id")
  stripeMonthlyPriceId         String?                    @map("stripe_monthly_price_id")
  stripeYearlyPriceId          String?                    @map("stripe_yearly_price_id")
  createdBy                    String?                    @map("created_by")
  updatedBy                    String?                    @map("updated_by")
  createdAt                    DateTime                   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                    DateTime                   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                    DateTime?                  @map("deleted_at") @db.Timestamptz

  creator               User?                  @relation("SubscriptionPlanCreator", fields: [createdBy], references: [id])
  updater               User?                  @relation("SubscriptionPlanUpdater", fields: [updatedBy], references: [id])
  customerSubscriptions CustomerSubscription[]

  @@index([status, visibility])
  @@index([deletedAt])
  @@map("subscription_plans")
}

model PlanFeatureCatalog {
  id          String    @id @default(cuid())
  key         String    @unique
  label       String
  description String?
  type        String    @default("BOOLEAN")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("plan_feature_catalog")
}

model UploadedFile {
  id              String             @id @default(cuid())
  ownerId         String             @map("owner_id")
  ownerRole       UserRole           @map("owner_role")
  targetAccountId String?            @map("target_account_id")
  folder          String
  fileName        String             @map("file_name")
  contentType     String             @map("content_type")
  sizeBytes       Int?               @map("size_bytes")
  fileUrl         String             @map("file_url")
  storageKey      String             @unique @map("storage_key")
  status          UploadedFileStatus @default(PENDING)
  giftId          String?            @map("gift_id")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  completedAt     DateTime?          @map("completed_at") @db.Timestamptz
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId, status])
  @@index([targetAccountId])
  @@index([giftId])
  @@index([folder, createdAt])
  @@index([deletedAt])
  @@map("uploaded_files")
}

model MediaUploadPolicy {
  id                   String   @id @default(cuid())
  allowedFileTypesJson Json     @default("{}") @map("allowed_file_types_json")
  maxImageSizeMb       Int      @default(10) @map("max_image_size_mb")
  maxVideoSizeMb       Int      @default(500) @map("max_video_size_mb")
  maxAudioSizeMb       Int      @default(50) @map("max_audio_size_mb")
  scanUploads          Boolean  @default(true) @map("scan_uploads")
  blockSvgUploads      Boolean  @default(true) @map("block_svg_uploads")
  updatedById          String?  @map("updated_by_id")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User? @relation("MediaUploadPolicyUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
  @@map("media_upload_policies")
}

model Coupon {
  id              String             @id @default(cuid())
  code            String             @unique
  description     String?
  discountType    CouponDiscountType @map("discount_type")
  discountValue   Decimal            @map("discount_value") @db.Decimal(10, 2)
  planIdsJson     Json               @default("[]") @map("plan_ids_json")
  startsAt        DateTime?          @map("starts_at") @db.Timestamptz
  expiresAt       DateTime?          @map("expires_at") @db.Timestamptz
  maxRedemptions  Int?               @map("max_redemptions")
  redemptionCount Int                @default(0) @map("redemption_count")
  isActive        Boolean            @default(true) @map("is_active")
  createdBy       String?            @map("created_by")
  updatedBy       String?            @map("updated_by")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz

  creator               User?                  @relation("CouponCreator", fields: [createdBy], references: [id])
  updater               User?                  @relation("CouponUpdater", fields: [updatedBy], references: [id])
