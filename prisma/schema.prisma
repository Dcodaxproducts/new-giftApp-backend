generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  REGISTERED_USER
  PROVIDER
}

enum ProviderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoginAttemptStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum AccountType {
  REGISTERED_USER
  PROVIDER
  ADMIN
}

enum GiftStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum GiftModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model User {
  id                        String                  @id @default(cuid())
  email                     String                  @unique
  password                  String
  role                      UserRole                @default(REGISTERED_USER)
  firstName                 String                  @map("first_name")
  lastName                  String                  @map("last_name")
  phone                     String?
  avatarUrl                 String?                 @map("avatar_url")
  location                  String?
  adminRoleId               String?                 @map("admin_role_id")
  isVerified                Boolean                 @default(false) @map("is_verified")
  isActive                  Boolean                 @default(true) @map("is_active")
  isApproved                Boolean                 @default(true) @map("is_approved")
  mustChangePassword        Boolean                 @default(false) @map("must_change_password")
  lastLoginAt               DateTime?               @map("last_login_at") @db.Timestamptz
  adminTitle                String?                 @map("admin_title")
  adminPermissions          Json?                   @map("admin_permissions")
  providerBusinessName      String?                 @map("provider_business_name")
  providerServiceArea       String?                 @map("provider_service_area")
  providerDocuments         Json?                   @map("provider_documents")
  providerApprovalStatus    ProviderApprovalStatus? @map("provider_approval_status")
  providerApprovedAt        DateTime?               @map("provider_approved_at") @db.Timestamptz
  providerApprovedBy        String?                 @map("provider_approved_by")
  providerRejectedAt        DateTime?               @map("provider_rejected_at") @db.Timestamptz
  providerRejectedBy        String?                 @map("provider_rejected_by")
  providerRejectionReason   String?                 @map("provider_rejection_reason")
  providerRejectionComment  String?                 @map("provider_rejection_comment")
  verificationOtp           String?                 @map("verification_otp")
  verificationOtpExpiresAt  DateTime?               @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts   Int                     @default(0) @map("verification_otp_attempts")
  resetPasswordOtp          String?                 @map("reset_password_otp")
  resetPasswordOtpExpiresAt DateTime?               @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts  Int                     @default(0) @map("reset_password_otp_attempts")
  suspensionReason          String?                 @map("suspension_reason")
  suspensionComment         String?                 @map("suspension_comment")
  suspendedAt               DateTime?               @map("suspended_at") @db.Timestamptz
  suspendedBy               String?                 @map("suspended_by")
  refreshTokenHash          String?                 @map("refresh_token_hash")
  deletedAt                 DateTime?               @map("deleted_at") @db.Timestamptz
  deleteAfter               DateTime?               @map("delete_after") @db.Timestamptz
  createdAt                 DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime                @updatedAt @map("updated_at") @db.Timestamptz
  loginAttempts             LoginAttempt[]
  adminRole                 AdminRole?              @relation(fields: [adminRoleId], references: [id])
  auditLogs                 AdminAuditLog[]         @relation("AuditActor")
  targetAuditLogs           AdminAuditLog[]         @relation("AuditTarget")
  accountSuspensions        AccountSuspension[]     @relation("SuspendedAccount")
  createdSuspensions        AccountSuspension[]     @relation("SuspensionActor")
  resolvedSuspensions       AccountSuspension[]     @relation("UnsuspensionActor")
  providerGifts             Gift[]                  @relation("GiftProvider")
  approvedGifts             Gift[]                  @relation("GiftApprover")
  rejectedGifts             Gift[]                  @relation("GiftRejecter")
  flaggedGifts              Gift[]                  @relation("GiftFlagger")

  @@index([role, isActive])
  @@index([role, suspendedAt])
  @@index([adminRoleId])
  @@index([providerApprovalStatus])
  @@map("users")
}

model GiftCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  iconKey     String?   @map("icon_key")
  color       String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  gifts Gift[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("gift_categories")
}

model Gift {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  description      String?
  shortDescription String?              @map("short_description")
  categoryId       String               @map("category_id")
  providerId       String               @map("provider_id")
  price            Decimal              @db.Decimal(10, 2)
  currency         String               @default("USD")
  stockQuantity    Int                  @default(0) @map("stock_quantity")
  sku              String?              @unique
  imageUrls        Json                 @default("[]") @map("image_urls")
  status           GiftStatus           @default(INACTIVE)
  moderationStatus GiftModerationStatus @default(PENDING) @map("moderation_status")
  isPublished      Boolean              @default(false) @map("is_published")
  isFeatured       Boolean              @default(false) @map("is_featured")
  tags             Json                 @default("[]")
  ratingPlaceholder Decimal             @default(4.8) @map("rating_placeholder") @db.Decimal(3, 2)
  approvedAt       DateTime?            @map("approved_at") @db.Timestamptz
  approvedBy       String?              @map("approved_by")
  rejectedAt       DateTime?            @map("rejected_at") @db.Timestamptz
  rejectedBy       String?              @map("rejected_by")
  rejectionReason  String?              @map("rejection_reason")
  rejectionComment String?              @map("rejection_comment")
  flaggedAt        DateTime?            @map("flagged_at") @db.Timestamptz
  flaggedBy        String?              @map("flagged_by")
  flagReason       String?              @map("flag_reason")
  flagComment      String?              @map("flag_comment")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?            @map("deleted_at") @db.Timestamptz

  category GiftCategory @relation(fields: [categoryId], references: [id])
  provider User         @relation("GiftProvider", fields: [providerId], references: [id])
  approver User?        @relation("GiftApprover", fields: [approvedBy], references: [id])
  rejecter User?        @relation("GiftRejecter", fields: [rejectedBy], references: [id])
  flagger  User?        @relation("GiftFlagger", fields: [flaggedBy], references: [id])

  @@index([categoryId, deletedAt])
  @@index([providerId, deletedAt])
  @@index([status, deletedAt])
  @@index([moderationStatus, deletedAt])
  @@index([isPublished, deletedAt])
  @@map("gifts")
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  permissions Json     @map("permissions_json")
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  admins User[]

  @@index([isActive, isSystem])
  @@map("admin_roles")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  targetId   String?  @map("target_id")
  targetType String?  @map("target_type")
  action     String
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditActor", fields: [actorId], references: [id])
  target User? @relation("AuditTarget", fields: [targetId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetId, createdAt])
  @@index([targetType, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

model AccountSuspension {
  id            String      @id @default(cuid())
  accountId     String      @map("account_id")
  accountType   AccountType @map("account_type")
  reason        String
  comment       String?
  suspendedBy   String      @map("suspended_by")
  suspendedAt   DateTime    @default(now()) @map("suspended_at") @db.Timestamptz
  unsuspendedBy String?     @map("unsuspended_by")
  unsuspendedAt DateTime?   @map("unsuspended_at") @db.Timestamptz
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  account       User        @relation("SuspendedAccount", fields: [accountId], references: [id])
  suspendActor  User        @relation("SuspensionActor", fields: [suspendedBy], references: [id])
  unsuspendActor User?      @relation("UnsuspensionActor", fields: [unsuspendedBy], references: [id])

  @@index([accountId, isActive])
  @@index([accountType, isActive])
  @@index([suspendedBy, suspendedAt])
  @@map("account_suspensions")
}

model LoginAttempt {
  id        String             @id @default(cuid())
  email     String
  status    LoginAttemptStatus
  reason    String?
  ipAddress String?            @map("ip_address")
  userAgent String?            @map("user_agent")
  userId    String?            @map("user_id")
  role      UserRole?
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("login_attempts")
}
