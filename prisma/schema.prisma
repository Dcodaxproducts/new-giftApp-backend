generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  REGISTERED_USER
  PROVIDER
}

enum ProviderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoginAttemptStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum AccountType {
  REGISTERED_USER
  PROVIDER
  ADMIN
}

enum GiftStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum GiftModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BroadcastChannel {
  EMAIL
  PUSH
  IN_APP
}

enum BroadcastPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  CANCELLED
  FAILED
}

enum BroadcastSendMode {
  NOW
  SCHEDULED
}

enum NotificationRecipientType {
  ADMIN
  PROVIDER
  REGISTERED_USER
}

enum BroadcastDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  OPENED
  CLICKED
}

enum NotificationDevicePlatform {
  IOS
  ANDROID
  WEB
}

enum SubscriptionPlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionPlanVisibility {
  PUBLIC
  PRIVATE
  ARCHIVED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromotionalOfferDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PromotionalOfferStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  INACTIVE
  PENDING
  REJECTED
}

enum PromotionalOfferApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PromotionalOfferRejectionReason {
  INVALID_DISCOUNT
  INVALID_DATES
  POLICY_VIOLATION
  ITEM_NOT_ELIGIBLE
  INCOMPLETE_INFORMATION
  OTHER
}

enum UploadedFileStatus {
  PENDING
  COMPLETED
  FAILED
  DELETED
}

enum CustomerReminderEventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  CUSTOM
}

enum CustomerDeliveryOption {
  SAME_DAY
  NEXT_DAY
  SCHEDULED
}

enum CustomerEventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  WORK_MILESTONE
  CUSTOM
}

enum CustomerEventReminderTiming {
  ONE_DAY_BEFORE
  THREE_DAYS_BEFORE
  ONE_WEEK_BEFORE
  ON_THE_DAY
  CUSTOM
}

enum CustomerEventReminderFrequency {
  ONE_TIME
  MONTHLY
  YEARLY
}

enum CustomerEventReminderChannel {
  PUSH
  EMAIL
  SMS
}

enum CustomerEventReminderJobStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  PLACEHOLDER
}

enum ProviderFulfillmentMethod {
  PICKUP
  DELIVERY
}

model User {
  id                        String                  @id @default(cuid())
  email                     String                  @unique
  password                  String
  role                      UserRole                @default(REGISTERED_USER)
  firstName                 String                  @map("first_name")
  lastName                  String                  @map("last_name")
  phone                     String?
  avatarUrl                 String?                 @map("avatar_url")
  location                  String?
  adminRoleId               String?                 @map("admin_role_id")
  isVerified                Boolean                 @default(false) @map("is_verified")
  isActive                  Boolean                 @default(true) @map("is_active")
  isApproved                Boolean                 @default(true) @map("is_approved")
  mustChangePassword        Boolean                 @default(false) @map("must_change_password")
  lastLoginAt               DateTime?               @map("last_login_at") @db.Timestamptz
  adminTitle                String?                 @map("admin_title")
  adminPermissions          Json?                   @map("admin_permissions")
  providerBusinessName      String?                 @map("provider_business_name")
  providerBusinessCategoryId String?                @map("provider_business_category_id")
  providerTaxId             String?                 @map("provider_tax_id")
  providerBusinessAddress   String?                 @map("provider_business_address")
  providerServiceArea       String?                 @map("provider_service_area")
  providerFulfillmentMethods Json?                  @map("provider_fulfillment_methods")
  providerAutoAcceptOrders  Boolean                 @default(false) @map("provider_auto_accept_orders")
  providerDocuments         Json?                   @map("provider_documents")
  providerApprovalStatus    ProviderApprovalStatus? @map("provider_approval_status")
  providerApprovedAt        DateTime?               @map("provider_approved_at") @db.Timestamptz
  providerApprovedBy        String?                 @map("provider_approved_by")
  providerRejectedAt        DateTime?               @map("provider_rejected_at") @db.Timestamptz
  providerRejectedBy        String?                 @map("provider_rejected_by")
  providerRejectionReason   String?                 @map("provider_rejection_reason")
  providerRejectionComment  String?                 @map("provider_rejection_comment")
  verificationOtp           String?                 @map("verification_otp")
  verificationOtpExpiresAt  DateTime?               @map("verification_otp_expires_at") @db.Timestamptz
  verificationOtpAttempts   Int                     @default(0) @map("verification_otp_attempts")
  resetPasswordOtp          String?                 @map("reset_password_otp")
  resetPasswordOtpExpiresAt DateTime?               @map("reset_password_otp_expires_at") @db.Timestamptz
  resetPasswordOtpAttempts  Int                     @default(0) @map("reset_password_otp_attempts")
  suspensionReason          String?                 @map("suspension_reason")
  suspensionComment         String?                 @map("suspension_comment")
  suspendedAt               DateTime?               @map("suspended_at") @db.Timestamptz
  suspendedBy               String?                 @map("suspended_by")
  refreshTokenHash          String?                 @map("refresh_token_hash")
  deletedAt                 DateTime?               @map("deleted_at") @db.Timestamptz
  deleteAfter               DateTime?               @map("delete_after") @db.Timestamptz
  createdAt                 DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime                @updatedAt @map("updated_at") @db.Timestamptz
  loginAttempts             LoginAttempt[]
  adminRole                 AdminRole?              @relation(fields: [adminRoleId], references: [id])
  auditLogs                 AdminAuditLog[]         @relation("AuditActor")
  accountSuspensions        AccountSuspension[]     @relation("SuspendedAccount")
  createdSuspensions        AccountSuspension[]     @relation("SuspensionActor")
  resolvedSuspensions       AccountSuspension[]     @relation("UnsuspensionActor")
  providerGifts             Gift[]                  @relation("GiftProvider")
  approvedGifts             Gift[]                  @relation("GiftApprover")
  rejectedGifts             Gift[]                  @relation("GiftRejecter")
  flaggedGifts              Gift[]                  @relation("GiftFlagger")
  promotionalOffers         PromotionalOffer[]       @relation("PromotionalOfferProvider")
  approvedPromotionalOffers PromotionalOffer[]       @relation("PromotionalOfferApprover")
  rejectedPromotionalOffers PromotionalOffer[]       @relation("PromotionalOfferRejecter")
  createdBroadcasts         Broadcast[]             @relation("BroadcastCreator")
  updatedBroadcasts         Broadcast[]             @relation("BroadcastUpdater")
  cancelledBroadcasts       Broadcast[]             @relation("BroadcastCanceller")
  notifications             Notification[]
  deviceTokens              NotificationDeviceToken[]
  notificationPreference    NotificationPreference?
  uploadedFiles             UploadedFile[]
  createdSubscriptionPlans  SubscriptionPlan[]      @relation("SubscriptionPlanCreator")
  updatedSubscriptionPlans  SubscriptionPlan[]      @relation("SubscriptionPlanUpdater")
  createdCoupons            Coupon[]                @relation("CouponCreator")
  updatedCoupons            Coupon[]                @relation("CouponUpdater")
  providerBusinessCategory  ProviderBusinessCategory? @relation(fields: [providerBusinessCategoryId], references: [id])

  @@index([role, isActive])
  @@index([role, suspendedAt])
  @@index([adminRoleId])
  @@index([providerApprovalStatus])
  @@index([providerBusinessCategoryId])
  @@map("users")
}

model ProviderBusinessCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconKey     String?  @map("icon_key")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  providers User[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("provider_business_categories")
}

model GiftCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  iconKey     String?   @map("icon_key")
  color       String?
  backgroundColor String? @default("#F3E8FF") @map("background_color")
  imageUrl    String?   @map("image_url")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  gifts Gift[]

  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@map("gift_categories")
}

model CustomerWishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  giftId    String   @map("gift_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, giftId])
  @@index([userId])
  @@index([giftId])
  @@map("customer_wishlists")
}

model CustomerAddress {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  label                String
  fullName             String    @map("full_name")
  phone                String
  line1                String
  line2                String?
  city                 String
  state                String?
  country              String
  postalCode           String?   @map("postal_code")
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  deliveryInstructions String?   @map("delivery_instructions")
  isDefault            Boolean   @default(false) @map("is_default")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  @@index([userId, deletedAt])
  @@index([userId, isDefault])
  @@map("customer_addresses")
}

model CustomerReminder {
  id            String                    @id @default(cuid())
  userId        String                    @map("user_id")
  title         String
  recipientName String                    @map("recipient_name")
  eventType     CustomerReminderEventType @map("event_type")
  reminderDate  DateTime                  @map("reminder_date") @db.Timestamptz
  notes         String?
  isActive      Boolean                   @default(true) @map("is_active")
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?                 @map("deleted_at") @db.Timestamptz

  @@index([userId, deletedAt])
  @@index([reminderDate, isActive])
  @@map("customer_reminders")
}

model CustomerContact {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  name         String
  relationship String?
  phone        String?
  email        String?
  address      String?
  likes        String?
  avatarUrl    String?   @map("avatar_url")
  birthday     DateTime? @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  events       CustomerEvent[]

  @@index([userId])
  @@index([userId, name])
  @@index([userId, relationship])
  @@index([userId, deletedAt])
  @@map("customer_contacts")
}

model CustomerEvent {
  id                String                         @id @default(cuid())
  userId            String                         @map("user_id")
  recipientId       String?                        @map("recipient_id")
  eventType         CustomerEventType              @map("event_type")
  title             String
  eventDate         DateTime                       @map("event_date") @db.Timestamptz
  reminderTiming    CustomerEventReminderTiming    @default(ON_THE_DAY) @map("reminder_timing")
  reminderFrequency CustomerEventReminderFrequency @default(ONE_TIME) @map("reminder_frequency")
  customAlertTime   String?                        @map("custom_alert_time")
  channelsJson      Json                           @default("[\"PUSH\"]") @map("channels_json")
  notes             String?
  isActive          Boolean                        @default(true) @map("is_active")
  lastReminderSentAt DateTime?                     @map("last_reminder_sent_at") @db.Timestamptz
  nextReminderAt    DateTime?                      @map("next_reminder_at") @db.Timestamptz
  createdAt         DateTime                       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?                      @map("deleted_at") @db.Timestamptz
  recipient         CustomerContact?               @relation(fields: [recipientId], references: [id])
  reminderJobs      CustomerEventReminderJob[]

  @@index([userId, deletedAt])
  @@index([userId, eventDate])
  @@index([userId, eventType])
  @@index([recipientId])
  @@map("customer_events")
}

model CustomerEventReminderJob {
  id            String                         @id @default(cuid())
  eventId       String                         @map("event_id")
  userId        String                         @map("user_id")
  scheduledFor  DateTime                       @map("scheduled_for") @db.Timestamptz
  channel       CustomerEventReminderChannel
  status        CustomerEventReminderJobStatus @default(PENDING)
  failureReason String?                        @map("failure_reason")
  sentAt        DateTime?                      @map("sent_at") @db.Timestamptz
  createdAt     DateTime                       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz
  event         CustomerEvent                  @relation(fields: [eventId], references: [id])

  @@index([eventId, status])
  @@index([userId, scheduledFor])
  @@map("customer_event_reminder_jobs")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  items     CartItem[]

  @@index([userId, status])
  @@map("carts")
}

model CartItem {
  id                      String                 @id @default(cuid())
  cartId                  String                 @map("cart_id")
  giftId                  String                 @map("gift_id")
  variantId               String?                @map("variant_id")
  providerId              String                 @map("provider_id")
  quantity                Int
  unitPriceSnapshot       Decimal                @map("unit_price_snapshot") @db.Decimal(10, 2)
  discountAmountSnapshot  Decimal                @default(0) @map("discount_amount_snapshot") @db.Decimal(10, 2)
  finalUnitPriceSnapshot  Decimal                @map("final_unit_price_snapshot") @db.Decimal(10, 2)
  promotionalOfferId      String?                @map("promotional_offer_id")
  deliveryOption          CustomerDeliveryOption @map("delivery_option")
  recipientContactId      String?                @map("recipient_contact_id")
  recipientName           String                 @map("recipient_name")
  recipientPhone          String                 @map("recipient_phone")
  recipientAddressId      String                 @map("recipient_address_id")
  eventId                 String?                @map("event_id")
  giftMessage             String?                @map("gift_message")
  messageMediaUrlsJson    Json                   @default("[]") @map("message_media_urls_json")
  scheduledDeliveryAt     DateTime?              @map("scheduled_delivery_at") @db.Timestamptz
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  cart                    Cart                   @relation(fields: [cartId], references: [id])
  gift                    Gift                   @relation(fields: [giftId], references: [id])
  variant                 GiftVariant?           @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([giftId])
  @@index([variantId])
  @@index([recipientContactId])
  @@index([eventId])
  @@map("cart_items")
}

model Order {
  id                  String        @id @default(cuid())
  userId              String        @map("user_id")
  orderNumber         String        @unique @map("order_number")
  status              OrderStatus   @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod       PaymentMethod @default(COD) @map("payment_method")
  subtotal            Decimal       @db.Decimal(10, 2)
  discountTotal       Decimal       @default(0) @map("discount_total") @db.Decimal(10, 2)
  deliveryFee         Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  total               Decimal       @db.Decimal(10, 2)
  deliveryAddressId   String        @map("delivery_address_id")
  recipientName       String        @map("recipient_name")
  recipientPhone      String        @map("recipient_phone")
  giftMessage         String?       @map("gift_message")
  scheduledDeliveryAt DateTime?     @map("scheduled_delivery_at") @db.Timestamptz
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  items               OrderItem[]
  providerOrders      ProviderOrder[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                 String      @id @default(cuid())
  orderId            String      @map("order_id")
  giftId             String      @map("gift_id")
  providerId         String      @map("provider_id")
  quantity           Int
  unitPrice          Decimal     @map("unit_price") @db.Decimal(10, 2)
  discountAmount     Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  finalUnitPrice     Decimal     @map("final_unit_price") @db.Decimal(10, 2)
  total              Decimal     @db.Decimal(10, 2)
  promotionalOfferId String?     @map("promotional_offer_id")
  status             OrderStatus @default(PENDING)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  order              Order       @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerId, status])
  @@map("order_items")
}

model ProviderOrder {
  id            String      @id @default(cuid())
  orderId       String      @map("order_id")
  providerId    String      @map("provider_id")
  status        OrderStatus @default(PENDING)
  subtotal      Decimal     @db.Decimal(10, 2)
  discountTotal Decimal     @default(0) @map("discount_total") @db.Decimal(10, 2)
  deliveryFee   Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  order         Order       @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerId, status])
  @@map("provider_orders")
}

model PromotionalOffer {
  id               String                          @id @default(cuid())
  providerId       String                          @map("provider_id")
  itemId           String                          @map("item_id")
  title            String
  description      String?
  discountType     PromotionalOfferDiscountType    @map("discount_type")
  discountValue    Decimal                         @map("discount_value") @db.Decimal(10, 2)
  startDate        DateTime                        @map("start_date") @db.Timestamptz
  endDate          DateTime?                       @map("end_date") @db.Timestamptz
  eligibilityRules String?                         @map("eligibility_rules")
  isActive         Boolean                         @default(true) @map("is_active")
  status           PromotionalOfferStatus          @default(PENDING)
  approvalStatus   PromotionalOfferApprovalStatus  @default(PENDING) @map("approval_status")
  approvedAt       DateTime?                       @map("approved_at") @db.Timestamptz
  approvedBy       String?                         @map("approved_by")
  rejectedAt       DateTime?                       @map("rejected_at") @db.Timestamptz
  rejectedBy       String?                         @map("rejected_by")
  rejectionReason  PromotionalOfferRejectionReason? @map("rejection_reason")
  rejectionComment String?                         @map("rejection_comment")
  createdBy        String?                         @map("created_by")
  updatedBy        String?                         @map("updated_by")
  deletedAt        DateTime?                       @map("deleted_at") @db.Timestamptz
  createdAt        DateTime                        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime                        @updatedAt @map("updated_at") @db.Timestamptz

  provider User @relation("PromotionalOfferProvider", fields: [providerId], references: [id])
  item     Gift @relation(fields: [itemId], references: [id])
  approver User? @relation("PromotionalOfferApprover", fields: [approvedBy], references: [id])
  rejecter User? @relation("PromotionalOfferRejecter", fields: [rejectedBy], references: [id])

  @@index([providerId, status])
  @@index([itemId, status])
  @@index([approvalStatus, status])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@map("promotional_offers")
}

model Gift {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  description      String?
  shortDescription String?              @map("short_description")
  categoryId       String               @map("category_id")
  providerId       String               @map("provider_id")
  price            Decimal              @db.Decimal(10, 2)
  currency         String               @default("USD")
  stockQuantity    Int                  @default(0) @map("stock_quantity")
  sku              String?              @unique
  imageUrls        Json                 @default("[]") @map("image_urls")
  status           GiftStatus           @default(INACTIVE)
  moderationStatus GiftModerationStatus @default(PENDING) @map("moderation_status")
  isPublished      Boolean              @default(false) @map("is_published")
  isFeatured       Boolean              @default(false) @map("is_featured")
  tags             Json                 @default("[]")
  ratingPlaceholder Decimal             @default(4.8) @map("rating_placeholder") @db.Decimal(3, 2)
  approvedAt       DateTime?            @map("approved_at") @db.Timestamptz
  approvedBy       String?              @map("approved_by")
  rejectedAt       DateTime?            @map("rejected_at") @db.Timestamptz
  rejectedBy       String?              @map("rejected_by")
  rejectionReason  String?              @map("rejection_reason")
  rejectionComment String?              @map("rejection_comment")
  flaggedAt        DateTime?            @map("flagged_at") @db.Timestamptz
  flaggedBy        String?              @map("flagged_by")
  flagReason       String?              @map("flag_reason")
  flagComment      String?              @map("flag_comment")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?            @map("deleted_at") @db.Timestamptz

  category GiftCategory @relation(fields: [categoryId], references: [id])
  provider User         @relation("GiftProvider", fields: [providerId], references: [id])
  approver User?        @relation("GiftApprover", fields: [approvedBy], references: [id])
  rejecter User?        @relation("GiftRejecter", fields: [rejectedBy], references: [id])
  flagger  User?        @relation("GiftFlagger", fields: [flaggedBy], references: [id])
  promotionalOffers PromotionalOffer[]
  variants GiftVariant[]
  cartItems CartItem[]

  @@index([categoryId, deletedAt])
  @@index([providerId, deletedAt])
  @@index([status, deletedAt])
  @@index([moderationStatus, deletedAt])
  @@index([isPublished, deletedAt])
  @@map("gifts")
}

model GiftVariant {
  id            String   @id @default(cuid())
  giftId        String   @map("gift_id")
  name          String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  sku           String?  @unique
  isPopular     Boolean  @default(false) @map("is_popular")
  isDefault     Boolean  @default(false) @map("is_default")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  gift      Gift       @relation(fields: [giftId], references: [id])
  cartItems CartItem[]

  @@index([giftId, isActive, sortOrder])
  @@map("gift_variants")
}

model Broadcast {
  id                 String            @id @default(cuid())
  title              String
  message            String
  imageUrl           String?           @map("image_url")
  ctaLabel           String?           @map("cta_label")
  ctaUrl             String?           @map("cta_url")
  channels           Json
  priority           BroadcastPriority @default(NORMAL)
  status             BroadcastStatus   @default(DRAFT)
  targetingJson      Json?             @map("targeting_json")
  estimatedReachJson Json?             @map("estimated_reach_json")
  sendMode           BroadcastSendMode? @map("send_mode")
  scheduledAt        DateTime?         @map("scheduled_at") @db.Timestamptz
  timezone           String?           @default("UTC")
  isRecurring        Boolean           @default(false) @map("is_recurring")
  recurrenceJson     Json?             @map("recurrence_json")
  createdBy          String            @map("created_by")
  updatedBy          String?           @map("updated_by")
  cancelledAt        DateTime?         @map("cancelled_at") @db.Timestamptz
  cancelledBy        String?           @map("cancelled_by")
  cancelReason       String?           @map("cancel_reason")
  startedAt          DateTime?         @map("started_at") @db.Timestamptz
  completedAt        DateTime?         @map("completed_at") @db.Timestamptz
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  creator   User  @relation("BroadcastCreator", fields: [createdBy], references: [id])
  updater   User? @relation("BroadcastUpdater", fields: [updatedBy], references: [id])
  canceller User? @relation("BroadcastCanceller", fields: [cancelledBy], references: [id])

  deliveries    BroadcastDelivery[]
  notifications Notification[]

  @@index([status, createdAt])
  @@index([scheduledAt, status])
  @@map("broadcasts")
}

model BroadcastDelivery {
  id                String                  @id @default(cuid())
  broadcastId       String                  @map("broadcast_id")
  recipientId       String                  @map("recipient_id")
  recipientType     NotificationRecipientType @map("recipient_type")
  channel           BroadcastChannel
  status            BroadcastDeliveryStatus @default(QUEUED)
  email             String?
  deviceTokenId     String?                 @map("device_token_id")
  failureReason     String?                 @map("failure_reason")
  providerMessageId String?                 @map("provider_message_id")
  queuedAt          DateTime                @default(now()) @map("queued_at") @db.Timestamptz
  sentAt            DateTime?               @map("sent_at") @db.Timestamptz
  deliveredAt       DateTime?               @map("delivered_at") @db.Timestamptz
  openedAt          DateTime?               @map("opened_at") @db.Timestamptz
  clickedAt         DateTime?               @map("clicked_at") @db.Timestamptz
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  broadcast Broadcast @relation(fields: [broadcastId], references: [id])

  @@index([broadcastId, status])
  @@index([recipientId, recipientType])
  @@map("broadcast_deliveries")
}

model Notification {
  id            String                    @id @default(cuid())
  recipientId   String                    @map("recipient_id")
  recipientType NotificationRecipientType @map("recipient_type")
  broadcastId   String?                   @map("broadcast_id")
  title         String
  message       String
  imageUrl      String?                   @map("image_url")
  iconKey       String?                   @map("icon_key")
  ctaUrl        String?                   @map("cta_url")
  metadataJson  Json?                     @map("metadata_json")
  actionsJson   Json?                     @map("actions_json")
  type          String                    @default("BROADCAST")
  isRead        Boolean                   @default(false) @map("is_read")
  readAt        DateTime?                 @map("read_at") @db.Timestamptz
  createdAt     DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?                 @map("deleted_at") @db.Timestamptz

  recipient User       @relation(fields: [recipientId], references: [id])
  broadcast Broadcast? @relation(fields: [broadcastId], references: [id])

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, type, createdAt])
  @@index([deletedAt])
  @@index([broadcastId])
  @@map("notifications")
}

model NotificationDeviceToken {
